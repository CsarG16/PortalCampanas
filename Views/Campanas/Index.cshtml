@model IEnumerable<PortalCampanas.Models.Campana>

<h2>Listado de Campañas</h2>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text" name="categoria" class="form-control" placeholder="Categoría">
        <input type="text" name="estado" class="form-control" placeholder="Estado">
        <button type="submit" class="btn btn-primary">Buscar</button>
    </div>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Categoría</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model) {
        <tr>
            <td>@item.Nombre</td>
            <td>@item.Categoria</td>
            <td>@item.Estado</td>
            <td>
                <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-info">Ver Detalle</a>
            </td>
        </tr>
        }
    </tbody>
</table>