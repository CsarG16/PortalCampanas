@model IEnumerable<PortalCampanas.Models.Campana>

@{
    ViewData["Title"] = "Gestión de Campañas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-3">
        <div>
            <h1 class="display-6 fw-bold text-dark mb-0">Portal de Campanas</h1>
            <p class="text-muted mb-0">Administración y monitoreo de promociones vigentes</p>
        </div>
        <div class="text-end">
            <span class="badge rounded-pill bg-danger px-3 py-2">
                @Model.Count() Campañas Registradas
            </span>
        </div>
    </div>

    <div class="card shadow-sm mb-4 border-0">
        <div class="card-header bg-dark text-white py-3">
            <h5 class="mb-0"><i class="bi bi-search me-2"></i>Filtros de Búsqueda</h5>
        </div>
        <div class="card-body bg-light">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label fw-bold small text-uppercase">Categoría</label>
                    <input type="text" name="categoria" class="form-control" placeholder="Ej: Electro, Hogar, Moda...">
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-bold small text-uppercase">Estado</label>
                    <select name="estado" class="form-select">
                        <option value="">-- Todos los Estados --</option>
                        <option value="Vigente">Vigente</option>
                        <option value="Proxima">Próxima</option>
                        <option value="Finalizada">Finalizada</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-danger w-100 fw-bold">
                        BUSCAR
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="table-responsive shadow rounded-3">
        <table class="table table-hover align-middle mb-0 bg-white">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Nombre de Campaña</th>
                    <th>Categoría</th>
                    <th>Estado</th>
                    <th class="text-center">Descuento</th>
                    <th class="text-end pe-4">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model) {
                <tr>
                    <td class="ps-4">
                        <div class="fw-bold text-dark">@item.Nombre</div>
                        <small class="text-muted">ID: #@item.Id</small>
                    </td>
                    <td>
                        <span class="text-secondary">@item.Categoria</span>
                    </td>
                    <td>
                        @{
                            var badgeClass = item.Estado == "Vigente" ? "bg-success" : 
                                            item.Estado == "Proxima" ? "bg-warning text-dark" : "bg-secondary";
                        }
                        <span class="badge @badgeClass rounded-pill px-3">
                            @item.Estado
                        </span>
                    </td>
                    <td class="text-center">
                        <span class="h5 mb-0 text-danger fw-bold">@item.DescuentoPct%</span>
                    </td>
                    <td class="text-end pe-4">
                        <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-outline-dark btn-sm rounded-pill px-3">
                            Ver Detalles
                        </a>
                    </td>
                </tr>
                }
                @if (!Model.Any()) {
                    <tr>
                        <td colspan="5" class="text-center py-5 text-muted">
                            <p class="mb-0">No se encontraron campañas con los filtros aplicados.</p>
                            <a asp-action="Index" class="btn btn-link text-danger">Ver todas las campañas</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>